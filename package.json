{
  "name": "jackssybin-static-blog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "new-post": "node scripts/new-post.mjs",
    "fetch-hot-news": "node scripts/fetch-hot-news.mjs",
    "update-content": "node scripts/update-content.mjs",
    "import:hugo-tutorials": "node scripts/import-hugo-tutorials.mjs",
    "sync:hugo": "node scripts/sync-site.mjs",
    "dev": "pnpm sync:hugo && hugo server --bind 0.0.0.0 --baseURL http://127.0.0.1:1313/",
    "build": "pnpm sync:hugo && hugo --destination public --minify --cleanDestinationDir",
    "preview": "hugo server --bind 0.0.0.0 --baseURL http://127.0.0.1:1313/",
    "build:hugo": "pnpm build",
    "nav:update": "python scripts/ai-nav/update.py",
    "baidu-push": "node scripts/baidu-push.mjs"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "hugo-bin": "^0.149.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "hugo-bin"
    ]
  },
  "packageManager": "pnpm@10.33.0"
}
